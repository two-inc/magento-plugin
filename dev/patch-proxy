#!/bin/bash
# Configure the Magento container to work behind an FRP reverse proxy.
#
# Two problems to solve:
# 1. The container's entrypoint resets base URLs from the URL env var on every
#    restart. We inject a custom-entrypoint.sh that runs AFTER the reset and
#    re-applies the proxy URLs.
# 2. PHP's built-in dev server doesn't handle X-Forwarded-Proto. FRP terminates
#    TLS but sends X-Forwarded-Proto: http. We patch the router to detect the
#    proxy via X-Forwarded-Host instead.
#
# Usage: docker exec <container> bash /data/extensions/workdir/dev/patch-proxy <proxy_url>
# Undo:  docker exec <container> bash /data/extensions/workdir/dev/patch-proxy --reset

set -e

PROXY_URL="$1"

# ── Reset mode ───────────────────────────────────────────────────────────────
if [ "$PROXY_URL" = "--reset" ]; then
    rm -f /data/custom-entrypoint.sh
    exit 0
fi

if [ -z "$PROXY_URL" ]; then
    echo "Usage: patch-proxy <proxy_url>"
    echo "       patch-proxy --reset"
    exit 1
fi

# ── 1. Patch PHP router for HTTPS detection (idempotent) ─────────────────────
ROUTER="/data/phpserver/router.php"
MARKER="Trust reverse proxy"

if ! grep -q "$MARKER" "$ROUTER" 2>/dev/null; then
    sed -i "/^header('Access-Control-Allow-Origin/i\\
// Trust reverse proxy: if request arrived via X-Forwarded-Host, treat as HTTPS\\
// (FRP server terminates TLS but forwards X-Forwarded-Proto as \"http\")\\
if (isset(\\\$_SERVER[\"HTTP_X_FORWARDED_HOST\"]) \&\& \\\$_SERVER[\"HTTP_X_FORWARDED_HOST\"] !== \"\") {\\
    \\\$_SERVER[\"HTTPS\"] = \"on\";\\
    \\\$_SERVER[\"SERVER_PORT\"] = 443;\\
}\\
" "$ROUTER"
fi

# ── 2. Write custom entrypoint that runs after base URL reset ─────────────────
cat > /data/custom-entrypoint.sh << ENTRYEOF
#!/bin/bash
# Auto-generated by dev/patch-proxy — sets proxy base URLs after entrypoint reset
php bin/magento config:set web/unsecure/base_url "${PROXY_URL}/"
php bin/magento config:set web/secure/base_url "${PROXY_URL}/"
php bin/magento config:set web/secure/base_link_url "${PROXY_URL}/"
php bin/magento config:set web/unsecure/base_link_url "${PROXY_URL}/"
php bin/magento config:set web/secure/use_in_frontend 1
php bin/magento config:set web/secure/use_in_adminhtml 1
php bin/magento cache:flush
ENTRYEOF
chmod +x /data/custom-entrypoint.sh

# ── 3. Apply immediately (for current session, before next restart) ───────────
php bin/magento config:set web/unsecure/base_url "${PROXY_URL}/" 2>&1 | grep -v Xdebug
php bin/magento config:set web/secure/base_url "${PROXY_URL}/" 2>&1 | grep -v Xdebug
php bin/magento config:set web/secure/use_in_frontend 1 2>&1 | grep -v Xdebug
php bin/magento config:set web/secure/use_in_adminhtml 1 2>&1 | grep -v Xdebug
php bin/magento cache:flush 2>&1 | grep -v Xdebug > /dev/null
echo "Proxy configured: ${PROXY_URL}"
