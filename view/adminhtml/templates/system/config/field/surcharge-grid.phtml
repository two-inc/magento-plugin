 * @var \Two\Gateway\Block\Adminhtml\System\Config\Field\SurchargeGrid $block
 */

$terms = $block->getActiveTerms();
$maxFixed = $block->getMaxFixed();
$maxPercentage = $block->getMaxPercentage();
$defaultTerm = $block->getDefaultTerm();
$isNonDefault = $block->isNonDefaultScope();
// One inherit control for the whole grid (not per-cell). Checked = the
// grid inherits the parent scope; unchecked = the grid is overridden
// here. hasScopeOverride() reflects whether an actual override row
// exists, so the checkbox starts in the right state.
$hasOverride  = $isNonDefault && $block->hasScopeOverride();
$inheriting   = $isNonDefault && !$hasOverride;
$inheritLabel = $block->getScope() === 'stores' ? __('Use Website Value') : __('Use Default Value');
$surchargeType = $block->getSurchargeType();
$currencyCode = $block->getBaseCurrencyCode();
$columns = ['fixed', 'percentage', 'limit'];
$columnLabels = [
    'fixed' => __('Fixed Amount'),
    'percentage' => __('Percentage'),
    'limit' => __('Limit'),
];
?>

<div id="surcharge-grid-container"
     data-terms="<?= $block->escapeHtmlAttr(json_encode($terms)) ?>"
     data-available-terms="<?= $block->escapeHtmlAttr(json_encode($block->getAvailablePaymentTerms())) ?>"
     data-default-term="<?= (int)$defaultTerm ?>"
     data-surcharge-type="<?= $block->escapeHtmlAttr($surchargeType) ?>"
     data-max-fixed="<?= $maxFixed === null ? '' : (int)$maxFixed ?>"
     data-max-percentage="<?= (int)$maxPercentage ?>"
     data-fees-url="<?= $block->escapeHtmlAttr($block->getFeesUrl()) ?>"
     data-scope="<?= $block->escapeHtmlAttr($block->getScope()) ?>"
     data-scope-id="<?= (int)$block->getScopeId() ?>"
     data-base-currency="<?= $block->escapeHtmlAttr($currencyCode) ?>"
     data-decimal-separator="<?= $block->escapeHtmlAttr($block->getDecimalSeparator()) ?>">

    <p class="surcharge-grid__no-terms note" <?= !empty($terms) ? 'style="display:none"' : '' ?>>
        <span><?= $block->escapeHtml(__('No payment terms selected. Select payment terms above to configure surcharges.')) ?></span>
    </p>

    <?php if ($isNonDefault): ?>
        <div class="surcharge-grid__inherit-control">
            <label>
                <input type="checkbox"
                       class="surcharge-grid__inherit-toggle"
                       <?= $inheriting ? 'checked="checked"' : '' ?>
                />
                <?= $block->escapeHtml($inheritLabel) ?>
            </label>
            <input type="hidden"
                   name="<?= $block->escapeHtmlAttr($block->getInheritFieldName()) ?>"
                   class="surcharge-grid__inherit-sentinel"
                   value="<?= $inheriting ? '1' : '0' ?>"
            />
        </div>
    <?php endif; ?>

    <table class="admin__table-secondary surcharge-grid" cellspacing="0" <?= empty($terms) ? 'style="display:none"' : '' ?>>
        <thead>
            <tr>
                <th class="surcharge-grid__term"><?= $block->escapeHtml(__('Term')) ?></th>
                <th class="surcharge-grid__fixed"><?= $block->escapeHtml($columnLabels['fixed']) ?></th>
                <th class="surcharge-grid__percentage"><?= $block->escapeHtml($columnLabels['percentage']) ?></th>
                <th class="surcharge-grid__limit"><?= $block->escapeHtml($columnLabels['limit']) ?></th>
            </tr>
        </thead>
        <tbody>
            <?php foreach ($terms as $days): ?>
                <?php $isDefault = ($days === $defaultTerm); ?>
                <tr class="surcharge-grid__row" data-term="<?= (int)$days ?>">
                    <td class="surcharge-grid__term">
                        <strong><?= (int)$days ?> <?= $block->escapeHtml(__('days')) ?></strong>
                        <?php if ($isDefault): ?>
                            <span class="surcharge-grid__default-badge">(<?= $block->escapeHtml(__('default')) ?>)</span>
                        <?php endif; ?>
                    </td>
                    <?php foreach ($columns as $col): ?>
                        <?php
                        $value = $block->getSavedValue($days, $col);
                        $name = $block->getFieldName($days, $col);
                        $max = ($col === 'fixed') ? $maxFixed : (($col === 'percentage') ? $maxPercentage : null);
                        // validate-number is intentionally NOT in this list.
                        // Its regex is locale-blind (period-only) and would
                        // reject Dutch admins typing "10,50". validate-zero-
                        // or-greater and validate-number-range both route
                        // input through $.mage.parseNumber, which is locale-
                        // aware (it normalises comma → period internally),
                        // so dropping validate-number lets the comma flow
                        // through natively without us pre-normalising.
                        $validateRules = [
                            '"validate-zero-or-greater":true',
                        ];
                        // null = no upper bound (e.g. brand has no fixed-fee
                        // max). Skip the range rule entirely; the field then
                        // accepts any positive value.
                        if ($max !== null && $max !== '') {
                            $validateRules[] = '"validate-number-range":"0-' . (int)$max . '"';
                        }
                        ?>
                        <td class="surcharge-grid__<?= $col ?>">
                            <input type="text"
                                   name="<?= $block->escapeHtmlAttr($name) ?>"
                                   value="<?= $block->escapeHtmlAttr($value) ?>"
                                   class="input-text admin__control-text surcharge-grid__input"
                                   data-column="<?= $col ?>"
                                   data-term="<?= (int)$days ?>"
                                   data-validate='{<?= $block->escapeHtmlAttr(implode(',', $validateRules)) ?>}'
                                   <?= $inheriting ? 'disabled="disabled"' : '' ?>
                            />
                        </td>
                    <?php endforeach; ?>
                </tr>
            <?php endforeach; ?>
        </tbody>
    </table>

    <p class="surcharge-grid__currency-note note" <?= empty($terms) ? 'style="display:none"' : '' ?>
       data-text-default="<?= $block->escapeHtmlAttr(__('Amounts are shown in %1.', $currencyCode)) ?>"
       data-text-degraded="<?= $block->escapeHtmlAttr(__('Amounts are shown in %1 unless otherwise stated.', $currencyCode)) ?>">
        <span><?= $block->escapeHtml(__('Amounts are shown in %1.', $currencyCode)) ?></span>
    </p>

    <?php
    $fl = $block->getFixedLimitLabel();
    $pl = $block->getPercentageLimitLabel();
    $limitSentence = __(
        'Enter a limit amount (in %1) if you do not want to charge your customer more than a specific amount. Leave the limit field empty if you don\'t want to impose a limit amount.',
        $block->getBaseCurrencySymbol()
    );
    ?>
    <p class="note surcharge-grid__helper-text surcharge-grid__helper-text--fixed" style="display:none">
        <span>
            <?= $block->escapeHtml(__('Enter the amount you want to charge your customer. Max %1.', $fl)) ?>
        </span>
    </p>
    <p class="note surcharge-grid__helper-text surcharge-grid__helper-text--percentage" style="display:none">
        <span>
            <?= $block->escapeHtml(__('Enter the percentage of the fee you want to charge your customer. Max: %1.', $pl)) ?>
            <?= $block->escapeHtml($limitSentence) ?>
        </span>
    </p>
    <p class="note surcharge-grid__helper-text surcharge-grid__helper-text--fixed_and_percentage" style="display:none">
        <span>
            <?= $block->escapeHtml(__('Enter the amount and percentage of the fee you want to charge your customer. Max %1 / %2.', $fl, $pl)) ?>
            <?= $block->escapeHtml($limitSentence) ?>
        </span>
    </p>

    <?php $currencyWarning = $block->getCurrencyWarning(); ?>
    <?php if ($currencyWarning): ?>
        <p class="note surcharge-grid__currency-warning">
            <span class="surcharge-tax-warning"><?= $block->escapeHtml($currencyWarning) ?></span>
        </p>
    <?php endif; ?>

</div>

<script type="text/x-magento-init">
{
    "#surcharge-grid-container": {
        "Two_Gateway/js/surcharge-grid": {}
    }
}
</script>
