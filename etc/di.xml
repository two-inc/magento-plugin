<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="ABN\Gateway\Api\Config\RepositoryInterface"
                type="ABN\Gateway\Model\Config\Repository"/>
    <preference for="ABN\Gateway\Api\Log\RepositoryInterface"
                type="ABN\Gateway\Model\Log\Repository"/>
    <preference for="ABN\Gateway\Api\Webapi\SoleTraderInterface"
                type="ABN\Gateway\Model\Webapi\SoleTrader"/>
    <preference for="ABN\Gateway\Api\Webapi\TermSelectionInterface"
                type="ABN\Gateway\Model\Webapi\TermSelection"/>
    <preference for="ABN\Gateway\Api\Webapi\SurchargesInterface"
                type="ABN\Gateway\Model\Webapi\Surcharges"/>
    <preference for="ABN\Gateway\Api\CurrencyRatesProviderInterface"
                type="ABN\Gateway\Model\CurrencyRatesProvider"/>

    <type name="ABN\Gateway\Logger\Handler">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>
    <type name="ABN\Gateway\Logger\ErrorLogger">
        <arguments>
            <argument name="name" xsi:type="string">TwoError</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">ABN\Gateway\Logger\Handler\Error</item>
            </argument>
        </arguments>
    </type>
    <type name="ABN\Gateway\Logger\DebugLogger">
        <arguments>
            <argument name="name" xsi:type="string">TwoDebug</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">ABN\Gateway\Logger\Handler\Debug</item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\Sales\Model\Order">
        <plugin name="abn-after-place-order"
                type="ABN\Gateway\Plugin\Model\Sales\AfterPlaceOrder" sortOrder="10"/>
    </type>
    <type name="Magento\Sales\Api\OrderRepositoryInterface">
        <plugin name="abn-order-surcharge-ext-attrs"
                type="ABN\Gateway\Plugin\Api\SurchargeExtensionAttributes" sortOrder="10"/>
    </type>
    <type name="Magento\Sales\Api\InvoiceRepositoryInterface">
        <plugin name="abn-invoice-surcharge-ext-attrs"
                type="ABN\Gateway\Plugin\Api\SurchargeExtensionAttributes" sortOrder="10"/>
    </type>
    <type name="Magento\Sales\Api\CreditmemoRepositoryInterface">
        <plugin name="abn-creditmemo-surcharge-ext-attrs"
                type="ABN\Gateway\Plugin\Api\SurchargeExtensionAttributes" sortOrder="10"/>
    </type>
    <virtualType name="Magento\Sales\Model\ResourceModel\Order\Grid">
        <arguments>
            <argument name="columns" xsi:type="array">
                <item name="two_surcharge_amount" xsi:type="string">sales_order.two_surcharge_amount</item>
                <item name="base_two_surcharge_amount" xsi:type="string">sales_order.base_two_surcharge_amount</item>
            </argument>
        </arguments>
    </virtualType>
    <type name="Magento\Sales\Model\Order\Pdf\Config">
        <arguments>
            <argument name="data" xsi:type="array">
                <item name="renderers" xsi:type="array">
                    <item name="invoice" xsi:type="array">
                        <item name="two_surcharge" xsi:type="array">
                            <item name="class" xsi:type="string">ABN\Gateway\Model\Pdf\Total\Surcharge</item>
                        </item>
                    </item>
                    <item name="creditmemo" xsi:type="array">
                        <item name="two_surcharge" xsi:type="array">
                            <item name="class" xsi:type="string">ABN\Gateway\Model\Pdf\Total\Surcharge</item>
                        </item>
                    </item>
                </item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\Config\Model\Config\TypePool">
        <arguments>
            <argument name="environment" xsi:type="array">
                <item name="payment/abn_payment/mode" xsi:type="string">1</item>
                <item name="payment/abn_payment/debug" xsi:type="boolean">1</item>
            </argument>
        </arguments>
    </type>
</config>
