<!--
/**
 * Copyright © Two.inc All rights reserved.
 * See COPYING.txt for license details.
 *
 * Hosts are listed for the canonical `*.two.inc` checkout origins
 * and are static XML; the BrandRegistryInterface seam cannot rewrite
 * them at runtime. Brand-overlay packages whose checkout lives on a
 * non-`two.inc` host MUST ship their own etc/csp_whitelist.xml in
 * the overlay module — Magento merges csp_whitelist files additively
 * so the overlay's hosts add to (not replace) this list.
 */
-->
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
        <policies>
            <policy id="form-action">
                <values>
                    <value id="production" type="host">*.two.inc</value>
                    <value id="sandbox" type="host">*.sandbox.two.inc</value>
                    <value id="demo" type="host">*.demo.two.inc</value>
                    <value id="staging" type="host">*.staging.two.inc</value>
                    <value id="release" type="host">*.release.two.inc</value>
                    <value id="experimental" type="host">*.experimental.two.inc</value>
                    <value id="perf" type="host">*.perf.two.inc</value>
                    <value id="cyber" type="host">*.cyber.two.inc</value>
                </values>
            </policy>
            <policy id="base-uri">
                <values>
                    <value id="production" type="host">*.two.inc</value>
                    <value id="sandbox" type="host">*.sandbox.two.inc</value>
                    <value id="demo" type="host">*.demo.two.inc</value>
                    <value id="staging" type="host">*.staging.two.inc</value>
                    <value id="release" type="host">*.release.two.inc</value>
                    <value id="experimental" type="host">*.experimental.two.inc</value>
                    <value id="perf" type="host">*.perf.two.inc</value>
                    <value id="cyber" type="host">*.cyber.two.inc</value>
                </values>
            </policy>
            <policy id="connect-src">
                <values>
                    <value id="production" type="host">*.two.inc</value>
                    <value id="sandbox" type="host">*.sandbox.two.inc</value>
                    <value id="demo" type="host">*.demo.two.inc</value>
                    <value id="staging" type="host">*.staging.two.inc</value>
                    <value id="release" type="host">*.release.two.inc</value>
                    <value id="experimental" type="host">*.experimental.two.inc</value>
                    <value id="perf" type="host">*.perf.two.inc</value>
                    <value id="cyber" type="host">*.cyber.two.inc</value>
                </values>
            </policy>
        </policies>
</csp_whitelist>
